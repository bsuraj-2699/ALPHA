# Market data providers
# Upstox (Indian equities — quotes, OHLC, corporate actions, live WebSocket).
# Tokens are refreshed daily at 09:00 IST by the FastAPI startup hook.
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_ACCESS_TOKEN=your_initial_upstox_access_token_here
# One-time auth code from the Upstox login dialog (used only until the
# refresh-token grant takes over).
UPSTOX_AUTH_CODE=
UPSTOX_REFRESH_TOKEN=
UPSTOX_REDIRECT_URI=http://localhost

# Screener.in (Indian fundamentals). Optional — paste your logged-in
# session cookie to unlock premium tables; without it most public fields
# still parse.
SCREENER_SESSION_COOKIE=

# LLMs — set any one (or more). The first provider in LLM_PROVIDER_PRIORITY
# with a non-empty key is used for parse / analysts / debate / judge.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Alternative to GEMINI_API_KEY for Google AI Studio Gemini:
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# Optional: comma-separated order (default: openai,anthropic,gemini,mistral,groq)
# LLM_PROVIDER_PRIORITY=openai,anthropic,gemini,mistral,groq

# Optional: force a LiteLLM model id for the active provider
# LLM_MODEL=gpt-4o-mini

# When the active provider is OpenAI and LLM_MODEL is unset:
# OPENAI_MODEL=gpt-4o

# Infrastructure
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://fin:fin@localhost:5432/fin
